{
  "name": "maxclicks",
  "version": "1.1.0",
  "description": "The official maxclicks Node.js SDK for API access",
  "author": "maxclicks",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "c": "npm run check",
    "l": "npm run lint.staged",
    "check": "tsc --noEmit",
    "build": "tsup",
    "test": "node --import tsx --test test/*.test.ts",
    "lint.staged": "cross-env STRICT_MODE=true npx lint-staged --verbose --continue-on-error",
    "publish:dev": "node scripts/publish-dev.js",
    "publish:canary": "node scripts/publish-canary.js",
    "publish:stable": "node scripts/publish-stable.js",
    "unpublish": "node scripts/unpublish.js",
    "prepublishOnly": "npm run build",
    "prepare": "lefthook install"
  },
  "keywords": [
    "maxclicks",
    "nodejs",
    "sdk",
    "typescript",
    "api",
    "crm",
    "email",
    "marketing",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/maxclicks-ai/maxclicks-node"
  },
  "homepage": "https://github.com/maxclicks-ai/maxclicks-node#readme",
  "bugs": {
    "url": "https://github.com/maxclicks-ai/maxclicks-node/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@types/node": "^25.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "lefthook": "^2.0.13",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1"
  }
}
